{
  "manifest_version": 3,
  "name": "LassDownloader",
  "version": "1.0.0",
  "description": "Professional download manager extension for LassDownloader",
  "author": "LassDownloader Team",
  "homepage_url": "https://github.com/lassdownloader",
  
  "permissions": [
    "downloads",
    "contextMenus",
    "nativeMessaging",
    "storage",
    "webRequest",
    "notifications",
    "activeTab"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["polyfill.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  
  "action": {
    "default_title": "LassDownloader",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L"
      },
      "description": "Open LassDownloader"
    }
  }
}
